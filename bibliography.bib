	file = {Preprint PDF:/Users/felix/Zotero/storage/5EMWN52C/Erickson et al. - 2020 - AutoGluon-Tabular Robust and Accurate AutoML for Structured Data.pdf:application/pdf;Snapshot:/Users/felix/Zotero/storage/NP2HNUX8/2003.html:text/html},
	keywords = {Computer Science - Machine Learning, Statistics - Machine Learning},
	month = mar,
	note = {arXiv:2003.06505 [stat]},
	publisher = {arXiv},
	shorttitle = {{AutoGluon}-{Tabular}},
	title = {{AutoGluon}-{Tabular}: {Robust} and {Accurate} {AutoML} for {Structured} {Data}},
	url = {http://arxiv.org/abs/2003.06505},
	urldate = {2026-01-13},
